if __name__ == '__main__':
    # 如果带有 --proxy 参数，则进入后台代理守护模式
    if len(sys.argv) > 1 and sys.argv[1] == '--proxy':
        # 加载配置
        config = {
            "game_path": r"C:\TLBB",
            "server_ip": "127.0.0.1",
            "login_port": "3732",
            "game_port": "3733",
            "game_args": "-fl C0A80108 3039 12D82B"
        }
        if os.path.exists("launcher_config.json"):
            try:
                with open("launcher_config.json", 'r', encoding='utf-8') as f:
                    config.update(json.load(f))
            except:
                pass
        run_proxy(config)
    else:
        # 进入 GUI 模式
        root = tk.Tk()
        app = LauncherApp(root)
        root.mainloop()
